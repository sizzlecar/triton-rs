# Vendored Triton source — fetched on demand by `crates/triton-sys/tools/fetch_vendor.sh`.
# Pinned to v3.2.0 (commit 9641643). NOT committed to keep the repo small;
# contributors run the fetch script (or `cargo build --features compile-triton`
# triggers it via build.rs).
crates/triton-sys/vendor/triton/

# bindgen output
crates/triton-sys/src/bindings.rs

# CMake artifacts
**/CMakeFiles
**/CMakeCache.txt
**/cmake_install.cmake

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store

# Local validation venv (Triton has no macOS wheel; we validate via Docker
# instead — see tools/README.md)
.venv-validation/
